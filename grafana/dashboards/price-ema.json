{
  "uid": "price-ema",
  "title": "Price & EMA",
  "tags": ["hpt"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "portfolio",
        "type": "custom",
        "label": "Portfolio",
        "current": { "text": "crypto", "value": "crypto" },
        "options": [
          { "text": "crypto", "value": "crypto", "selected": true }
        ],
        "query": "crypto",
        "includeAll": false,
        "multi": false
      },
      {
        "name": "symbol",
        "type": "query",
        "label": "Symbol",
        "datasource": "Prometheus",
        "query": "label_values(analyst_symbol_price{job=\"${portfolio}-trader\"}, symbol)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Price & EMA — ${symbol}",
      "type": "timeseries",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "analyst_symbol_price{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Close Price", "refId": "A" },
        { "expr": "analyst_symbol_fast_ema{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Fast EMA", "refId": "B" },
        { "expr": "analyst_symbol_slow_ema{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Slow EMA", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 3,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Close Price" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "white" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Fast EMA" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Slow EMA" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Trend Status — ${symbol}",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [{ "expr": "analyst_symbol_trend_ok{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Trend OK" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "BEARISH", "color": "red" }, "1": { "text": "BULLISH", "color": "green" } } }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Momentum Score — ${symbol}",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "targets": [{ "expr": "analyst_symbol_momentum_score{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Momentum" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 3 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "Position Held — ${symbol}",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "targets": [{ "expr": "analyst_symbol_held{job=\"${portfolio}-trader\", symbol=\"${symbol}\"}", "legendFormat": "Held" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "NO", "color": "blue" }, "1": { "text": "YES", "color": "orange" } } }],
          "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    }
  ],
  "schemaVersion": 39
}
