# Copy this file to .env and fill in your Kraken API credentials.
# All other values have sensible defaults and can be left as-is.

# ── Kraken API (required for live trading) ───────────────────────────────────
KRAKEN_API_KEY=REPLACE_ME
KRAKEN_API_SECRET=REPLACE_ME

# ── Trading behaviour ────────────────────────────────────────────────────────
DRY_RUN=false          # set true to paper-trade (no real orders sent)
MAX_POSITIONS=5
STOP_LOSS_PCT=0.08

# ── LLM Signal Service ───────────────────────────────────────────────────────
LLM_API_KEY=hpt_live_....
LLM_API_BASE_URL=https://api.broker.harrispartners.tech/v1
LLM_MODEL=hpt-short
# RSS_FEED_URLS=url1;url2   (optional override — defaults to CoinDesk, Cointelegraph, Decrypt, CryptoSlate)
GDELT_ENABLED=true
# GDELT_QUERY=bitcoin OR ethereum OR crypto OR blockchain   (optional override)
# GDELT_MAX_RECORDS=50
# GDELT_TIMESPAN=2h

# ── Trader signal gate ───────────────────────────────────────────────────────
SIGNAL_GATE_ENABLED=false
SIGNAL_LOOKBACK_HOURS=24
SIGNAL_CONFIDENCE_THRESHOLD=0.70
SIGNAL_BLOCK_HORIZONS=1-7d,1-4w,structural
