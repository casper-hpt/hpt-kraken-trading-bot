# =============================================================================
# Harris Partners Technologies
# =============================================================================
#
# HPT Kraken Trading Bot - Environment Variable Reference
#
# =============================================================================


# =============================================================================
# SHARED — QuestDB
# =============================================================================
# Data collectors use HTTP (port 9000), strategies use PGWire (port 8812)
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest              # SECRET
QUESTDB_DBNAME=qdb


# =============================================================================
# crypto-data-collector
# =============================================================================
PROMETHEUS_PORT=9092
INGEST_INTERVAL_MINUTES=1           # poll cadence for 15m bars
LOG_LEVEL=INFO


# =============================================================================
# crypto-trader
# =============================================================================
KRAKEN_API_KEY=REPLACE_ME           # SECRET
KRAKEN_API_SECRET=REPLACE_ME        # SECRET
DRY_RUN=false
PROMETHEUS_PORT=9095
CYCLE_INTERVAL=15
MAX_POSITIONS=5
SETTLEMENT_DELAY_SECONDS=5.0
POSITIONS_PATH=/data/positions.json
VERBOSE=false
