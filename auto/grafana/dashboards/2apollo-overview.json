{
  "uid": "2apollo-overview",
  "title": "2Apollo Overview",
  "tags": ["2apollo"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "portfolio",
        "type": "custom",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "crypto", "value": "crypto", "selected": false }
        ],
        "query": "crypto",
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 100,
      "title": "Strategy",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Active Positions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [{ "expr": "analyst_active_positions", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 3,
      "title": "Buy / Sell Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "rate(analyst_cycle_buys_total[5m]) * 60", "legendFormat": "{{job}} buys/min" },
        { "expr": "rate(analyst_cycle_sells_total[5m]) * 60", "legendFormat": "{{job}} sells/min" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 5,
      "title": "Rebalance Cycles (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [{ "expr": "rate(analyst_rebalance_cycles_total[5m]) * 60", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "title": "Rebalance Cycle Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [{ "expr": "analyst_rebalance_cycle_duration_seconds", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 101,
      "title": "Data Collectors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Bars Inserted (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [{ "expr": "rate(collector_bars_inserted_total[5m]) * 60", "legendFormat": "{{job}}" }]
    },
    {
      "id": 9,
      "title": "Watchlist Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "targets": [{ "expr": "collector_watchlist_size", "legendFormat": "{{job}}" }]
    },
    {
      "id": 7,
      "title": "API Errors (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [{ "expr": "rate(collector_api_errors_total[5m]) * 60", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 8,
      "title": "Cycle Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [{ "expr": "collector_cycle_duration_seconds", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },

    {
      "id": 102,
      "title": "Traders",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Buys Attempted vs Succeeded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "targets": [
        { "expr": "rate(trader_buys_attempted_total[5m]) * 60", "legendFormat": "{{job}} attempted/min" },
        { "expr": "rate(trader_buys_succeeded_total[5m]) * 60", "legendFormat": "{{job}} succeeded/min" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 11,
      "title": "Sells Attempted vs Succeeded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "targets": [
        { "expr": "rate(trader_sells_attempted_total[5m]) * 60", "legendFormat": "{{job}} attempted/min" },
        { "expr": "rate(trader_sells_succeeded_total[5m]) * 60", "legendFormat": "{{job}} succeeded/min" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 12,
      "title": "Trader Errors (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "targets": [
        { "expr": "rate(trader_errors_total[5m]) * 60", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 13,
      "title": "Message Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 63 },
      "targets": [{ "expr": "trader_message_latency_seconds", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 22,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 71 },
      "targets": [{ "expr": "trader_active_users", "legendFormat": "{{job}}" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 23,
      "title": "Token Refreshes",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 71 },
      "targets": [{ "expr": "rate(trader_token_refreshes_total[5m]) * 60", "legendFormat": "refreshes/min" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 24,
      "title": "Token Refresh Errors",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 71 },
      "targets": [{ "expr": "rate(trader_token_refresh_errors_total[5m]) * 60", "legendFormat": "errors/min" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 25,
      "title": "Discovery Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 71 },
      "targets": [{ "expr": "trader_user_discovery_errors", "legendFormat": "{{job}}" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 103,
      "title": "Unrealized P&L",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 75 },
      "collapsed": false
    },
    {
      "id": 14,
      "title": "Crypto Unrealized P&L",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 76 },
      "targets": [{ "expr": "analyst_position_unrealized_pnl{job=\"crypto-trader\"}", "legendFormat": "{{symbol}} (slot {{slot_id}})" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10, "gradientMode": "scheme" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 104,
      "title": "Open Positions",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 84 },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Crypto Positions",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 85 },
      "targets": [
        { "expr": "analyst_position_entry_price{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "A" },
        { "expr": "analyst_position_current_price{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "B" },
        { "expr": "analyst_position_unrealized_pnl{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "C" },
        { "expr": "analyst_position_bars_held{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "D" }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(symbol|slot_id|Value .*)$"
            }
          }
        },
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "symbol": "Symbol",
              "slot_id": "Slot",
              "Value #A": "Entry Price",
              "Value #B": "Current Price",
              "Value #C": "Unrealized PnL",
              "Value #D": "Bars Held"
            },
            "indexByName": {
              "Symbol": 0,
              "Slot": 1,
              "Entry Price": 2,
              "Current Price": 3,
              "Unrealized PnL": 4,
              "Bars Held": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Unrealized PnL" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Entry Price" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Current Price" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          }
        ]
      }
    },

    {
      "id": 105,
      "title": "Momentum & Signals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 95 },
      "collapsed": false
    },
    {
      "id": 18,
      "title": "Crypto Momentum Scores",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 96 },
      "targets": [
        { "expr": "analyst_symbol_momentum_score{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "A" },
        { "expr": "analyst_symbol_trend_ok{job=\"crypto-trader\"}", "instant": true, "format": "table", "refId": "B" }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(symbol|Value .*)$"
            }
          }
        },
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "symbol": "Symbol",
              "Value #A": "Momentum Score",
              "Value #B": "Trend OK"
            },
            "indexByName": {
              "Symbol": 0,
              "Momentum Score": 1,
              "Trend OK": 2
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Momentum Score", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "decimals": 4 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Momentum Score" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "blue", "value": 0.01 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Trend OK" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "NO", "color": "red" }, "1": { "text": "YES", "color": "green" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }
            ]
          }
        ]
      }
    },

    {
      "id": 106,
      "title": "Data Freshness",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 114 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Crypto Data Freshness",
      "description": "How old each symbol's latest bar is (in minutes), sorted by age.",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 115 },
      "targets": [{ "expr": "(time() - analyst_symbol_last_bar_ts{job=\"crypto-trader\"}) / 60", "instant": true, "format": "table", "refId": "A" }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "symbol": "Symbol", "Value": "Data Age (min)" }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Data Age (min)", "desc": false }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "decimals": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Data Age (min)" },
            "properties": [
              { "id": "unit", "value": "m" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] } }
            ]
          }
        ]
      }
    },

    {
      "id": 107,
      "title": "Order Slippage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 123 },
      "collapsed": false
    },
    {
      "id": 27,
      "title": "Crypto Order Slippage",
      "description": "Fill price minus strategy entry price per symbol. Positive = paid more than expected.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 124 },
      "targets": [{ "expr": "trader_order_slippage{job=\"crypto-trader\"}", "legendFormat": "{{symbol}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": { "fillOpacity": 10, "gradientMode": "scheme", "lineWidth": 2 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0 }, { "color": "red", "value": 0.01 }] },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ],
  "schemaVersion": 39
}
